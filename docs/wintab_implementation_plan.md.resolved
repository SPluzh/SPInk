## Фаза 3 — FormCollection.cs: интеграция WinTab

### 3.1 Инициализация

```csharp
protected override void OnHandleCreated(EventArgs e)
{
    base.OnHandleCreated(e);
    if (Root.PressureSensitivity && Root.PressureSource == 0)
    {
        if (!WinTabManager.Open(this.Handle))
            Root.PressureSensitivity = false;
    }
}
```

### 3.2 Закрытие

```csharp
protected override void OnFormClosed(FormClosedEventArgs e)
{
    WinTabManager.Close();
    base.OnFormClosed(e);
}
```

### 3.3 WndProc

```csharp
protected override void WndProc(ref Message m)
{
    if (m.Msg == WinTabManager.WT_PACKET && Root.PressureSensitivity
        && Root.PressureSource == 0)
    {
        uint serial = (uint)m.WParam.ToInt32();
        float p = WinTabManager.ReadPressure(serial);
        if (p >= 0f)
            Root.CurrentPressure = ApplyPressureCurve(p);
        return; // сообщение потреблено
    }
    if (m.Msg == WinTabManager.WT_PROXIMITY)
    {
        bool entering = (m.LParam.ToInt32() & 0xFFFF) != 0;
        if (!entering) Root.CurrentPressure = 0.5f;
    }
    base.WndProc(ref m);
}

private float ApplyPressureCurve(float raw)
{
    return Root.PressureMinScale
         + (Root.PressureMaxScale - Root.PressureMinScale) * raw;
}
```

> [!NOTE]
> `lcMoveMask = 0` — WM_WINTAB не генерируется при простом движении, только при нажатии.

### 3.4 IC_MouseMove — выбор источника давления

```csharp
private void IC_MouseMove(object sender, CancelMouseEventArgs e)
{
    if (Root.PressureSensitivity)
    {
        switch (Root.PressureSource)
        {
            case 0: // WinTab — CurrentPressure уже обновлён из WndProc
                if (!WinTabManager.IsAvailable)
                    Root.CurrentPressure = 0.5f;
                break;

            case 1: // Microsoft.Ink NormalPressure
                // Читаем из последнего пакета текущего штриха
                int[] pkData = Root.IC.Ink.Strokes[Root.IC.Ink.Strokes.Count - 1]
                                   .GetPacketData(new int[]{}, PacketProperty.NormalPressure);
                if (pkData != null && pkData.Length > 0)
                {
                    float raw = pkData[pkData.Length - 1] / 1023f;
                    Root.CurrentPressure = ApplyPressureCurve(
                        Math.Max(0f, Math.Min(1f, raw)));
                }
                break;

            case 2: // Fixed
            default:
                Root.CurrentPressure = 0.5f;
                break;
        }
    }
    else
    {
        Root.CurrentPressure = 0.5f;
    }

    // Записать в буфер давления текущего штриха
    if (Root.PressureSensitivity)
        Root.CurrentStrokePressure.Add(Root.CurrentPressure);

    // ... существующий код IC_MouseMove ...
}
```

> [!NOTE]
> При `PressureSource = 1` WinTab не открывается совсем — нет конфликтов на Surface/WM_POINTER планшетах.

