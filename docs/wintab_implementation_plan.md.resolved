## Фаза 2 — Root.cs: глобальное состояние давления

```csharp
// --- Pressure Sensitivity ---
public static float CurrentPressure   = 0.5f;
public static bool  PressureSensitivity = false;
public static float PressureMinScale  = 0.2f;
public static float PressureMaxScale  = 1.5f;

/// <summary>
/// Источник данных о давлении:
///   0 = WinTab  (WinTab32.dll — Wacom/XP-Pen/Huion)
///   1 = Microsoft.Ink NormalPressure (встроен в InkOverlay, без доп. драйверов)
///   2 = Fixed   (всегда 0.5f — давление отключено, ширина постоянная)
/// </summary>
public static int PressureSource = 0;

// Буфер давления текущего штриха
public static List<float> CurrentStrokePressure = new List<float>();

// Давление по завершённым штрихам. Ключ: Stroke.Id
public static Dictionary<int, float[]> StrokePressureData
    = new Dictionary<int, float[]>();
```

**ReadOptions():**
```csharp
PressureSensitivity = ReadBool("PressureSensitivity", false);
PressureMinScale    = ReadFloat("PressureMinScale", 0.2f);
PressureMaxScale    = ReadFloat("PressureMaxScale", 1.5f);
PressureSource      = ReadInt("PressureSource", 0); // 0=WinTab, 1=Ink, 2=Fixed
```

**SaveOptions():**
```csharp
WriteValue("PressureSensitivity", PressureSensitivity ? "1" : "0");
WriteValue("PressureMinScale",    PressureMinScale.ToString("F2"));
WriteValue("PressureMaxScale",    PressureMaxScale.ToString("F2"));
WriteValue("PressureSource",      PressureSource.ToString());
```

