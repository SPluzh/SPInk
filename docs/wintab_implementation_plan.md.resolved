## Фаза 5 — FormDisplay.cs: посегментный рендеринг

```csharp
private float GetPressureWidth(int strokeId, int pointIndex, int totalPoints)
{
    float baseWidth = Root.GlobalPenWidth * DpiScale / 26.458f;
    if (!Root.PressureSensitivity) return baseWidth;

    float[] pressures;
    if (!Root.StrokePressureData.TryGetValue(strokeId, out pressures))
        return baseWidth;

    float t = totalPoints > 1
        ? (float)pointIndex / (totalPoints - 1) * (pressures.Length - 1) : 0;
    int lo = (int)t;
    int hi = Math.Min(lo + 1, pressures.Length - 1);
    float pressure = pressures[lo] * (1 - (t - lo)) + pressures[hi] * (t - lo);
    return baseWidth * pressure;
}

private void DrawStrokeWithPressure(Graphics g, Stroke stroke)
{
    int count = stroke.PacketCount;
    if (count < 2) return;

    Point[] pts = stroke.GetPoints();
    PointF[] pixPts = new PointF[count];
    for (int i = 0; i < count; i++)
    {
        Point p = pts[i];
        IC.Renderer.InkSpaceToPixel(g, ref p);
        pixPts[i] = new PointF(p.X, p.Y);
    }

    Color col = stroke.DrawingAttributes.Color;
    for (int i = 0; i < count - 1; i++)
    {
        float w = Math.Max(0.5f,
            (GetPressureWidth(stroke.Id, i, count) +
             GetPressureWidth(stroke.Id, i + 1, count)) / 2f);
        using (Pen pen = new Pen(col, w))
        {
            pen.StartCap = pen.EndCap = LineCap.Round;
            pen.LineJoin = LineJoin.Round;
            g.DrawLine(pen, pixPts[i], pixPts[i + 1]);
        }
    }
}
```

> [!WARNING]
> `new Pen(...)` в цикле — дорого при 500+ точках. Оптимизация: пул перьев `Dictionary<float, Pen>` с округлением ширины до 0.5px.

